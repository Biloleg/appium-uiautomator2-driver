+     */
+    private _isInternalPage(url: string): boolean {
+        const internalPagePrefixes = [
+            'chrome://',
+            'chrome-devtools://',
+            'about:',
+            'data:',
+        ];
+        return internalPagePrefixes.some(prefix => url.startsWith(prefix));
+    }
+
+    /**
+     * Connect to webview via CDP
