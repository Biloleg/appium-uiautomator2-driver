+                return {
+                    x: Math.round((rect.left + window.scrollX) * dpr),
+                    y: Math.round((rect.top + window.scrollY) * dpr),
+                    width: Math.round(rect.width * dpr),
+                    height: Math.round(rect.height * dpr)
+                };
