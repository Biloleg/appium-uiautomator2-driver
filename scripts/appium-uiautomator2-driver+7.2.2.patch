+    async getElementAttribute(elementId: string, attributeName: string): Promise<string | null> {
+        const cachedValue = this.elementCache.get(elementId);
+        if (!cachedValue) {
+            throw new Error(`Element not found in cache: ${elementId}`);
+        }
