+                try {
+                    await this.adb.adbExec(['forward', '--remove', `tcp:${context.localPort}`]);
+                } catch (error) {
+                    this.logger.warn(`[CDP] Failed to remove port forward: ${error}`);
+                }
+            }
+        }
+
+        this.contexts.clear();
+        this.currentContext = 'NATIVE_APP';
+    }
+}
