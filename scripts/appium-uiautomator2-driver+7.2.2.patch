+        return null;
+    }
+
+    /**
+     * Get cached viewport dimensions (if available)
+     */
+    getCachedViewportDimensions(): { width: number; height: number } | null {
+        return this.cachedViewportDimensions;
+    }
+
+    /**
+     * Update cached viewport dimensions
